{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.2.0",
  "description": "__MSG_appDesc__",
  "default_locale": "es",

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "gestor-descargas-hector@ayarachi.com",
      "strict_min_version": "142.0"
    }
  },

  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "__MSG_appName__"
  },

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "contextMenus",
    "tabs"
  ],

  "host_permissions": [],

  "web_accessible_resources": [
    {
      "resources": [
        "icon16.png",
        "icon48.png",
        "icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
